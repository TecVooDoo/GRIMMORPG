# ===========================
# GRIMMORPG .gitignore
# ===========================
# Only track GRPG-owned files: _GRIMMORPG/, Documents/, ProjectSettings/, Packages/
# All third-party assets are excluded and installed locally.

# ===========================
# Unity generated
# ===========================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ===========================
# IDE / OS
# ===========================
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
Thumbs.db
.DS_Store

# ===========================
# Unity build artifacts
# ===========================
*.apk
*.aab
*.unitypackage
*.app
sysinfo.txt
crashlytics-build.properties

# ===========================
# Local config (machine-specific)
# ===========================
.claude/
.mcp.json
.vsconfig

# ===========================
# Asset cache
# ===========================
Assets/DownloadCache/
Assets/DownloadCache.meta
Assets/Editor Default Resources/
